@model YunChenShipping.Models.ShippingOrder
@{
    ViewData["Title"] = "出貨單管理 / 編輯出貨單";
    var customers = ViewBag.Customers as List<YunChenShipping.Models.Customer>;
}

<form asp-action="Edit" method="post" id="orderForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedBy" />

    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-file-text"></i> 基本資料
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 出貨單號</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="OrderNo" class="form-control" readonly />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 出貨日期</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="OrderDate" class="form-control" type="date" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 客戶</label>
                </div>
                <div class="col-md-4">
                    <select asp-for="CustomerId" class="form-select" id="customerSelect">
                        <option value="">請選擇客戶</option>
                        @if (customers != null)
                        {
                            @foreach (var customer in customers)
                            {
                                <option value="@customer.Id" selected="@(customer.Id == Model.CustomerId)">@customer.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">付款方式</label>
                </div>
                <div class="col-md-4">
                    <select asp-for="PaymentMethod" class="form-select"
                            asp-items="Html.GetEnumSelectList<YunChenShipping.Models.PaymentMethod>()">
                    </select>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">訂單號碼</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="ReferenceNo" class="form-control" placeholder="選填" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">案號</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="ProjectNo" class="form-control" placeholder="選填" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">發票號碼</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="InvoiceNo" class="form-control" placeholder="選填，可事後補登" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">承辦人</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="Handler" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 交貨地址</label>
                </div>
                <div class="col-md-10">
                    <textarea asp-for="DeliveryAddress" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">運送方式</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="DeliveryMethod" class="form-control" placeholder="例：自送、宅配、貨運" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">備註</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- 產品明細 -->
    <div class="form-card">
        <div class="form-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ul"></i> 產品明細</span>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addDetail()">
                <i class="bi bi-plus"></i> 新增明細
            </button>
        </div>
        <div class="form-card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="detailTable">
                    <thead>
                        <tr>
                            <th style="width: 50px;">項次</th>
                            <th style="width: 180px;">產品</th>
                            <th>產品名稱</th>
                            <th>PART NO</th>
                            <th style="width: 100px;">數量</th>
                            <th style="width: 100px;">單位</th>
                            <th style="width: 110px;">單價</th>
                            <th style="width: 110px;">小計</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody id="detailBody">
                        @if (Model.Details != null && Model.Details.Any())
                        {
                            @foreach (var detail in Model.Details.OrderBy(d => d.LineNo))
                            {
                                <tr>
                                    <td>@detail.LineNo</td>
                                    <td>
                                        <select name="ProductIds" class="form-select form-select-sm product-select" onchange="updateProductInfo(this)">
                                            <option value="">請選擇產品</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" name="ProductNames" class="form-control form-control-sm" value="@(detail.ProductName ?? detail.Product?.Name ?? "")" />
                                    </td>
                                    <td>
                                        <input type="text" name="PartNos" class="form-control form-control-sm" value="@(detail.PartNo ?? detail.Product?.PartNo ?? "")" readonly />
                                    </td>
                                    <td>
                                        <input type="number" name="Quantities" class="form-control quantity-input"
                                               min="1" value="@detail.Quantity" onchange="calculateRow(this)" />
                                    </td>
                                    <td>
                                        <input type="text" name="Units" class="form-control form-control-sm" value="@(detail.Unit ?? detail.Product?.Unit ?? "")" readonly />
                                    </td>
                                    <td>
                                        <input type="number" name="UnitPrices" class="form-control form-control-sm price-input"
                                               step="0.01" value="@detail.UnitPrice" onchange="calculateRow(this)" />
                                    </td>
                                    <td>
                                        <span class="subtotal-display fw-bold">@detail.SubTotal.ToString("N2")</span>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeDetail(this)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td>1</td>
                                <td>
                                    <select name="ProductIds" class="form-select form-select-sm product-select" onchange="updateProductInfo(this)">
                                        <option value="">請選擇產品</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" name="ProductNames" class="form-control form-control-sm" />
                                </td>
                                <td>
                                    <input type="text" name="PartNos" class="form-control" readonly />
                                </td>
                                <td>
                                    <input type="number" name="Quantities" class="form-control quantity-input"
                                           min="1" value="1" onchange="calculateRow(this)" />
                                </td>
                                <td>
                                    <input type="text" name="Units" class="form-control" readonly />
                                </td>
                                <td>
                                    <input type="number" name="UnitPrices" class="form-control form-control-sm price-input"
                                           step="0.01" onchange="calculateRow(this)" />
                                </td>
                                <td>
                                    <span class="subtotal-display fw-bold">0</span>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeDetail(this)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 金額摘要 -->
            <div class="row justify-content-end mt-3">
                <div class="col-md-4">
                    <div class="form-card" style="margin-bottom: 0;">
                        <div class="form-card-body">
                            <div class="row mb-2">
                                <div class="col-6"><strong>銷售額：</strong></div>
                                <div class="col-6 text-end" id="subTotal">@Model.SubTotal.ToString("N2")</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-6"><strong>營業稅（5%）：</strong></div>
                                <div class="col-6 text-end" id="taxAmount">@Model.TaxAmount.ToString("N2")</div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-6"><strong>其他費用：</strong></div>
                                <div class="col-6">
                                    <input type="number" asp-for="OtherExpenses" class="form-control form-control-sm text-end"
                                           step="0.01" onchange="calculateTotal()" style="width: 120px; float: right;" />
                                </div>
                            </div>
                            <hr />
                            <div class="row">
                                <div class="col-6"><strong class="text-primary fs-5">總計：</strong></div>
                                <div class="col-6 text-end"><strong class="text-primary fs-5" id="totalAmount">@Model.Total.ToString("N2")</strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 按鈕 -->
    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left"></i> 回上一頁
        </a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> 儲存修改
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        var products = [];

        $(document).ready(function() {
            loadProducts();
        });

        function loadProducts() {
            $.get('/Product/Search?term=', function(data) {
                products = data;
                updateProductSelects();
            });
        }

        function updateProductSelects() {
            $('.product-select').each(function() {
                var select = $(this);
                var currentValue = select.val();
                select.find('option:gt(0)').remove();
                products.forEach(function(product) {
                    select.append(`<option value="${product.id}"
                        data-name="${product.name}"
                        data-unit="${product.unit}"
                        data-price="${product.standardPrice}"
                        data-partno="${product.partNo}"
                        data-taxtype="${product.taxType}">${product.partNo} - ${product.name}</option>`);
                });
                if (currentValue) {
                    select.val(currentValue);
                }
            });
        }

        function addDetail() {
            var idx = $('#detailBody tr').length;
            var html = `
                <tr>
                    <td>${idx + 1}</td>
                    <td>
                        <select name="ProductIds" class="form-select form-select-sm product-select" onchange="updateProductInfo(this)">
                            <option value="">請選擇產品</option>
                        </select>
                    </td>
                    <td>
                        <input type="text" name="ProductNames" class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input type="text" name="PartNos" class="form-control" readonly />
                    </td>
                    <td>
                        <input type="number" name="Quantities" class="form-control quantity-input"
                               min="1" value="1" onchange="calculateRow(this)" />
                    </td>
                    <td>
                        <input type="text" name="Units" class="form-control" readonly />
                    </td>
                    <td>
                        <input type="number" name="UnitPrices" class="form-control form-control-sm price-input"
                               step="0.01" onchange="calculateRow(this)" />
                    </td>
                    <td>
                        <span class="subtotal-display fw-bold">0</span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeDetail(this)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                </tr>
            `;
            $('#detailBody').append(html);
            updateProductSelects();
        }

        function removeDetail(btn) {
            if ($('#detailBody tr').length > 1) {
                btn.closest('tr').remove();
                renumberRows();
                calculateTotal();
            }
        }

        function renumberRows() {
            $('#detailBody tr').each(function(index) {
                $(this).find('td:first').text(index + 1);
            });
        }

        function updateProductInfo(select) {
            var option = $(select).find('option:selected');
            var row = $(select).closest('tr');
            if (option.val()) {
                row.find('input[name="ProductNames"]').val(option.data('name'));
                row.find('input[name="PartNos"]').val(option.data('partno'));
                row.find('input[name="Units"]').val(option.data('unit'));
                row.find('.price-input').val(option.data('price'));
                calculateRow(select);
            }
        }

        function calculateRow(element) {
            var row = $(element).closest('tr');
            var quantity = parseInt(row.find('.quantity-input').val()) || 0;
            var price = parseFloat(row.find('.price-input').val()) || 0;
            var subtotal = quantity * price;
            row.find('.subtotal-display').text(subtotal.toFixed(2));
            calculateTotal();
        }

        function calculateTotal() {
            var subTotal = 0;
            var taxableAmount = 0;

            $('#detailBody tr').each(function() {
                var quantity = parseInt($(this).find('.quantity-input').val()) || 0;
                var price = parseFloat($(this).find('.price-input').val()) || 0;
                var lineTotal = quantity * price;
                subTotal += lineTotal;

                var select = $(this).find('.product-select');
                var option = select.find('option:selected');
                if (option.data('taxtype') === 0) {
                    taxableAmount += lineTotal;
                }
            });

            var taxAmount = Math.round(taxableAmount * 0.05);
            var otherExpenses = parseFloat($('#OtherExpenses').val()) || 0;
            var total = subTotal + taxAmount + otherExpenses;

            $('#subTotal').text(subTotal.toFixed(2));
            $('#taxAmount').text(taxAmount.toFixed(2));
            $('#totalAmount').text(total.toFixed(2));
        }

        $('#customerSelect').change(function() {
            var customerId = $(this).val();
            if (customerId) {
                $.get('/ShippingOrder/GetCustomer?id=' + customerId, function(data) {
                    if (data.address) {
                        $('#DeliveryAddress').val(data.address);
                    }
                    if (data.contactPerson) {
                        $('#Handler').val(data.contactPerson);
                    }
                    if (data.paymentMethod !== undefined) {
                        $('#PaymentMethod').val(data.paymentMethod);
                    }
                });
            }
        });
    </script>
}
