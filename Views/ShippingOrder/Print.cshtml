@model YunChenShipping.Models.ShippingOrder
@{
    ViewData["Title"] = "列印出貨單";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <title>列印出貨單 - @Model.OrderNo</title>
    <style>
        * { font-family: "標楷體", "DFKai-SB", serif; font-size: 9pt; margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #f0f0f0; padding: 10px; }
        .print-buttons { text-align: center; margin-bottom: 10px; }
        .print-buttons button { margin: 0 10px; padding: 8px 25px; font-size: 14px; }
        .paper { width: 215mm; min-height: 138mm; margin: 0 auto; background: white; padding: 3mm 8mm; }

        .header { display: flex; justify-content: space-between; margin-bottom: 2mm; }
        .header-left { width: 30%; } .header-center { width: 40%; text-align: center; } .header-right { width: 30%; }
        .header-center h2 { font-size: 16pt; letter-spacing: 6px; margin-bottom: 1mm; }
        .header-center p { font-size: 8pt; line-height: 1.4; }
        .info-row { display: flex; margin-bottom: 1mm; font-size: 9pt; line-height: 1.6; white-space: nowrap; }
        .info-label { flex-shrink: 0; white-space: nowrap; } .info-value { flex: 1; border-bottom: 1px solid #000; white-space: nowrap; overflow: hidden; }

        .main-table { width: 100%; border-collapse: collapse; }
        .main-table th, .main-table td { border: 1px solid #000; padding: 0.5mm 1mm; text-align: center; font-size: 9pt; height: 7mm; }
        .main-table th { background: #f5f5f5; }

        .footer-section { display: flex; margin-top: 2mm; gap: 2mm; }
        .footer-left { flex: 1; border: 1px solid #000; padding: 2mm; font-size: 9pt; }
        .footer-right { width: 180px; border: 1px solid #000; }
        .footer-right table { width: 100%; border-collapse: collapse; }
        .footer-right td { border: 1px solid #000; padding: 2mm 3mm; font-size: 9pt; }
        .footer-right .label-cell { width: 55px; background: #f5f5f5; }
        .tax-row { display: flex; margin-bottom: 1.5mm; gap: 3mm; font-size: 9pt; }
        .tax-item { display: flex; align-items: center; gap: 2mm; }
        .tax-box { width: 28px; border: 1px solid #000; text-align: center; padding: 1mm; }

        .signature-section { display: flex; justify-content: space-between; margin-top: 3mm; padding: 0 15mm; font-size: 9pt; }
        .signature-item { display: flex; align-items: flex-end; gap: 2mm; }
        .signature-line { width: 100px; border-bottom: 1px solid #000; height: 1px; }
        .copies-info { text-align: center; margin-top: 2mm; font-size: 8pt; border-top: 1px dashed #999; padding-top: 1mm; }

        @@media print { .print-buttons { display: none; } body { background: white; padding: 0; } .paper { border: none; page-break-inside: avoid; } @@page { size: 215mm auto; margin: 0; } }
    </style>
</head>
<body>
    <div class="print-buttons">
        <button onclick="window.print()">列印</button>
        <button onclick="window.close()">關閉</button>
    </div>

    <div class="paper">
        <!-- 頂部三欄 -->
        <div class="header">
            <div class="header-left">
                <div class="info-row"><span class="info-label">客戶名稱:</span><span class="info-value">@Model.Customer?.Name</span></div>
                <div class="info-row"><span class="info-label">電　話:</span><span class="info-value">@(Model.Customer?.Phone ?? "")</span></div>
                <div class="info-row"><span class="info-label">聯絡人:</span><span class="info-value">@(Model.Customer?.ContactPerson ?? Model.Handler ?? "")</span></div>
                <div class="info-row"><span class="info-label">交貨地址:</span><span class="info-value">@Model.DeliveryAddress</span></div>
            </div>
            <div class="header-center">
                <h2>允晨科技有限公司</h2>
                <p>@(ViewBag.CompanyAddress as string ?? "300048新竹市北區竹光路363號")</p>
                <p>TEL：@(ViewBag.CompanyPhone as string ?? "03-5427772")　FAX：@(ViewBag.CompanyFax as string ?? "03-5427758")</p>
                <h2 style="letter-spacing: 10px; margin-top: 2mm;">出 貨 單</h2>
            </div>
            <div class="header-right">
                <div class="info-row"><span class="info-label">出貨單號:</span><span class="info-value">@Model.OrderNo</span></div>
                <div class="info-row"><span class="info-label">發票號碼:</span><span class="info-value">@(Model.InvoiceNo ?? "")</span></div>
                <div class="info-row"><span class="info-label">出貨日期:</span><span class="info-value">@Model.OrderDate.ToString("yyyy/MM/dd")</span></div>
                <div class="info-row"><span class="info-label">訂單號碼:</span><span class="info-value">@(Model.ReferenceNo ?? "")</span></div>
                <div class="info-row"><span class="info-label">案　號:</span><span class="info-value">@(Model.ProjectNo ?? "")</span></div>
                <div class="info-row"><span class="info-label">付款方式:</span><span class="info-value">@Html.DisplayFor(model => model.PaymentMethod)</span></div>
            </div>
        </div>

        <!-- 明細表格 + 客戶簽名 -->
        <table class="main-table">
            <thead>
                <tr>
                    <th style="width:35px;">項次</th>
                    <th>產品名稱及規格</th>
                    <th style="width:70px;">PART NO</th>
                    <th style="width:45px;">數量</th>
                    <th style="width:35px;">單位</th>
                    <th style="width:60px;">單價</th>
                    <th style="width:65px;">總價</th>
                    <th style="width:90px;" rowspan="7" style="vertical-align:middle;">客 戶 簽 名</th>
                </tr>
            </thead>
            <tbody>
                @{ var totalRows = 6; }
                @foreach (var detail in Model.Details.OrderBy(d => d.LineNo).Take(totalRows))
                {
                    <tr>
                        <td>@detail.LineNo</td>
                        <td style="text-align:left;">@(detail.ProductName ?? detail.Product?.Name ?? "")</td>
                        <td>@(detail.PartNo ?? detail.Product?.PartNo ?? "")</td>
                        <td>@detail.Quantity</td>
                        <td>@(detail.Unit ?? detail.Product?.Unit ?? "")</td>
                        <td style="text-align:right;">@detail.UnitPrice.ToString("N2")</td>
                        <td style="text-align:right;">@detail.SubTotal.ToString("N2")</td>
                    </tr>
                }
                @for (int i = Model.Details.Count; i < totalRows; i++)
                {
                    <tr><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
                }
            </tbody>
        </table>

        <!-- 底部 -->
        <div class="footer-section">
            <div class="footer-left">
                <div class="tax-row">
                    <div class="tax-item"><span>應稅</span><div class="tax-box">@(Model.TaxAmount > 0 ? "V" : "")</div></div>
                    <div class="tax-item"><span>零稅</span><div class="tax-box">@(Model.TaxAmount == 0 && Model.SubTotal > 0 ? "V" : "")</div></div>
                    <div class="tax-item" style="margin-left: auto;"><span>其他</span><span style="border-bottom:1px solid #000;min-width:50px;display:inline-block;">@(Model.OtherExpenses > 0 ? Model.OtherExpenses.ToString("N0") : "")</span></div>
                    <div class="tax-item"><span>運送方式：</span><span style="border-bottom:1px solid #000;min-width:50px;display:inline-block;">@(Model.DeliveryMethod ?? "")</span></div>
                </div>
                <div style="border-top:1px solid #000;padding-top:1mm;margin-top:1mm;">
                    <div style="margin-bottom:1mm;">備　註：</div>
                    <div style="min-height:8mm;">@(Model.Remarks ?? "")</div>
                </div>
            </div>
            <div class="footer-right">
                <table>
                    <tr><td class="label-cell">銷售額</td><td style="text-align:right;">@Model.SubTotal.ToString("N2")</td></tr>
                    <tr><td class="label-cell">營業稅</td><td style="text-align:right;">@Model.TaxAmount.ToString("N2")</td></tr>
                    <tr><td class="label-cell" style="font-weight:bold;">總 計</td><td style="text-align:right;font-weight:bold;">@Model.Total.ToString("N2")</td></tr>
                </table>
            </div>
        </div>

        <!-- 簽名 -->
        <div class="signature-section">
            <div class="signature-item">
                <span>主管：</span>
                @if (Model.ManagerApproved)
                {
                    <span style="border-bottom:1px solid #000;min-width:100px;display:inline-block;text-align:center;">@Model.ManagerName</span>
                }
                else
                {
                    <div class="signature-line"></div>
                }
            </div>
            <div class="signature-item">
                <span>會計：</span>
                @if (Model.AccountingApproved)
                {
                    <span style="border-bottom:1px solid #000;min-width:100px;display:inline-block;text-align:center;">@Model.AccountingName</span>
                }
                else
                {
                    <div class="signature-line"></div>
                }
            </div>
            <div class="signature-item">
                <span>承辦：</span>
                @if (Model.HandlerApproved)
                {
                    <span style="border-bottom:1px solid #000;min-width:100px;display:inline-block;text-align:center;">@Model.Handler</span>
                }
                else
                {
                    <div class="signature-line"></div>
                }
            </div>
        </div>
        <div class="copies-info">第一聯：存根聯(白)　　第二聯：會計聯(藍)　　第三聯：客戶聯(黃)</div>
    </div>
</body>
</html>
