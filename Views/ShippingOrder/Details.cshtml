@model YunChenShipping.Models.ShippingOrder
@{
    ViewData["Title"] = "出貨單管理 / 出貨單詳情";
}

<!-- 基本資料 -->
<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-file-text"></i> 基本資料
    </div>
    <div class="form-card-body">
        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">出貨單號</label>
            </div>
            <div class="col-md-4">
                <span class="fw-bold">@Model.OrderNo</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">狀態</label>
            </div>
            <div class="col-md-4">
                @switch (Model.Status)
                {
                    case YunChenShipping.Models.OrderStatus.Draft:
                        <span class="badge bg-secondary">草稿</span>
                        break;
                    case YunChenShipping.Models.OrderStatus.PendingApproval:
                        <span class="badge bg-warning">待簽核</span>
                        break;
                    case YunChenShipping.Models.OrderStatus.Shipped:
                        <span class="badge bg-primary">已出貨</span>
                        break;
                    case YunChenShipping.Models.OrderStatus.Completed:
                        <span class="badge bg-success">已完成</span>
                        break;
                    case YunChenShipping.Models.OrderStatus.Cancelled:
                        <span class="badge bg-danger">作廢</span>
                        break;
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">客戶名稱</label>
            </div>
            <div class="col-md-4">
                <span>@Model.Customer?.Name</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">出貨日期</label>
            </div>
            <div class="col-md-4">
                <span>@Model.OrderDate.ToString("yyyy/MM/dd")</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">訂單號碼</label>
            </div>
            <div class="col-md-4">
                <span>@(Model.ReferenceNo ?? "-")</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">案號</label>
            </div>
            <div class="col-md-4">
                <span>@(Model.ProjectNo ?? "-")</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">發票號碼</label>
            </div>
            <div class="col-md-4">
                <span>@(Model.InvoiceNo ?? "-")</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">付款方式</label>
            </div>
            <div class="col-md-4">
                <span>@Html.DisplayFor(model => model.PaymentMethod)</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">交貨地址</label>
            </div>
            <div class="col-md-10">
                <span>@Model.DeliveryAddress</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">運送方式</label>
            </div>
            <div class="col-md-4">
                <span>@(Model.DeliveryMethod ?? "-")</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">承辦人</label>
            </div>
            <div class="col-md-4">
                <span>@ViewBag.HandlerChineseName</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">備註</label>
            </div>
            <div class="col-md-10">
                <span>@(Model.Remarks ?? "-")</span>
            </div>
        </div>
    </div>
</div>

<!-- 產品明細 -->
<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-list-ul"></i> 產品明細
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>項次</th>
                        <th>產品名稱及規格</th>
                        <th>PART NO</th>
                        <th class="text-end">數量</th>
                        <th>單位</th>
                        <th class="text-end">單價</th>
                        <th class="text-end">小計</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.Details.OrderBy(d => d.LineNo))
                    {
                        <tr>
                            <td>@detail.LineNo</td>
                            <td>@(detail.ProductName ?? detail.Product?.Name)</td>
                            <td>@(detail.PartNo ?? detail.Product?.PartNo)</td>
                            <td class="text-end">@detail.Quantity</td>
                            <td>@(detail.Unit ?? detail.Product?.Unit)</td>
                            <td class="text-end">@(detail.UnitPrice == 0 ? "" : detail.UnitPrice.ToString("N2"))</td>
                            <td class="text-end fw-bold">@(detail.SubTotal == 0 ? "" : detail.SubTotal.ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <td colspan="6" class="text-end"><strong>銷售額</strong></td>
                        <td class="text-end"><strong>@(Model.SubTotal == 0 ? "" : Model.SubTotal.ToString("N0"))</strong></td>
                    </tr>
                    <tr class="table-light">
                        <td colspan="6" class="text-end"><strong>營業稅</strong></td>
                        <td class="text-end"><strong>@(Model.TaxAmount == 0 ? "" : Model.TaxAmount.ToString("N0"))</strong></td>
                    </tr>
                    @if (Model.OtherExpenses > 0)
                    {
                        <tr class="table-light">
                            <td colspan="6" class="text-end"><strong>其他費用</strong></td>
                            <td class="text-end"><strong>@Model.OtherExpenses.ToString("N2")</strong></td>
                        </tr>
                    }
                    <tr class="table-primary">
                        <td colspan="6" class="text-end"><strong class="fs-5">總計</strong></td>
                        <td class="text-end"><strong class="fs-5">@(Model.Total == 0 ? "" : Model.Total.ToString("N0"))</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- 簽核區 -->
<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-pencil-square"></i> 簽核區
    </div>
    <div class="form-card-body">
        @{
            var isAdmin = User.IsInRole("Admin");
            var isAccounting = User.IsInRole("Accounting");
            var canApprove = Model.Status == YunChenShipping.Models.OrderStatus.PendingApproval ||
                            Model.Status == YunChenShipping.Models.OrderStatus.Draft;
            // 簽核順序：主管 → 會計 → 承辦
            var managerFirst = !Model.ManagerApproved;
            var accountingCanApprove = Model.ManagerApproved && !Model.AccountingApproved;
            var handlerCanApprove = Model.ManagerApproved && Model.AccountingApproved && !Model.HandlerApproved;
        }
        <div class="row">
            <!-- 主管簽核 -->
            <div class="col-md-4">
                <div class="card @(Model.ManagerApproved ? "border-success" : (managerFirst && canApprove ? "border-warning" : "border-secondary"))">
                    <div class="card-header @(Model.ManagerApproved ? "bg-success text-white" : "bg-light")">
                        <i class="bi bi-person-badge"></i> ① 主管簽核
                    </div>
                    <div class="card-body text-center">
                        @if (Model.ManagerApproved)
                        {
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                            <p class="mt-2 mb-1"><strong>@Model.ManagerName</strong></p>
                            <p class="text-muted mb-0">@Model.ManagerApprovedAt?.ToString("yyyy/MM/dd HH:mm")</p>
                        }
                        else
                        {
                            <i class="bi bi-clock text-secondary" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">待簽核</p>
                            @if (canApprove && isAdmin)
                            {
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="mt-2">
                                    <input type="hidden" name="approveType" value="manager" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg"></i> 簽核
                                    </button>
                                </form>
                            }
                            else if (canApprove)
                            {
                                <p class="text-warning small mt-2 fw-bold">需管理員先簽核</p>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- 會計簽核 -->
            <div class="col-md-4">
                <div class="card @(Model.AccountingApproved ? "border-success" : (accountingCanApprove && canApprove ? "border-warning" : "border-secondary"))">
                    <div class="card-header @(Model.AccountingApproved ? "bg-success text-white" : "bg-light")">
                        <i class="bi bi-calculator"></i> ② 會計簽核
                    </div>
                    <div class="card-body text-center">
                        @if (Model.AccountingApproved)
                        {
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                            <p class="mt-2 mb-1"><strong>@Model.AccountingName</strong></p>
                            <p class="text-muted mb-0">@Model.AccountingApprovedAt?.ToString("yyyy/MM/dd HH:mm")</p>
                        }
                        else if (!Model.ManagerApproved)
                        {
                            <i class="bi bi-lock text-secondary" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">等待主管簽核</p>
                        }
                        else
                        {
                            <i class="bi bi-clock text-secondary" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">待簽核</p>
                            @if (canApprove && (isAdmin || isAccounting))
                            {
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="mt-2">
                                    <input type="hidden" name="approveType" value="accounting" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg"></i> 簽核
                                    </button>
                                </form>
                            }
                            else if (canApprove)
                            {
                                <p class="text-warning small mt-2 fw-bold">需會計簽核</p>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- 承辦簽核 -->
            <div class="col-md-4">
                <div class="card @(Model.HandlerApproved ? "border-success" : (handlerCanApprove && canApprove ? "border-warning" : "border-secondary"))">
                    <div class="card-header @(Model.HandlerApproved ? "bg-success text-white" : "bg-light")">
                        <i class="bi bi-person-check"></i> ③ 承辦簽核
                    </div>
                    <div class="card-body text-center">
                        @if (Model.HandlerApproved)
                        {
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                            <p class="mt-2 mb-1"><strong>@Model.Handler</strong></p>
                            <p class="text-muted mb-0">@Model.HandlerApprovedAt?.ToString("yyyy/MM/dd HH:mm")</p>
                        }
                        else if (!Model.ManagerApproved || !Model.AccountingApproved)
                        {
                            <i class="bi bi-lock text-secondary" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">等待前序簽核</p>
                        }
                        else
                        {
                            <i class="bi bi-clock text-secondary" style="font-size: 3rem;"></i>
                            <p class="mt-2 text-muted">待簽核</p>
                            @if (canApprove && (isAdmin || User.Identity?.Name == Model.Handler))
                            {
                                <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="mt-2">
                                    <input type="hidden" name="approveType" value="handler" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg"></i> 簽核
                                    </button>
                                </form>
                            }
                            else if (canApprove)
                            {
                                <p class="text-warning small mt-2 fw-bold">需承辦人簽核</p>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 簽核進度 -->
        <div class="mt-3 text-center">
            <small class="text-muted">
                簽核流程：① 主管 → ② 會計 → ③ 承辦
                @if (Model.ManagerApproved && Model.AccountingApproved && Model.HandlerApproved)
                {
                    <span class="badge bg-success ms-2">全部簽核完成</span>
                }
            </small>
        </div>
    </div>
</div>

<!-- 操作按鈕 -->
<div class="d-flex justify-content-center gap-3 mt-4">
    <a asp-action="Index" class="btn btn-secondary px-4">
        <i class="bi bi-arrow-left"></i> 回上一頁
    </a>
    <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-info px-4" target="_blank">
        <i class="bi bi-printer"></i> 列印預覽
    </a>
    <a asp-action="Copy" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4">
        <i class="bi bi-copy"></i> 複製出貨單
    </a>
    @if (Model.Status == YunChenShipping.Models.OrderStatus.Draft)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
            <i class="bi bi-pencil"></i> 編輯
        </a>
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
            <input type="hidden" name="status" value="@YunChenShipping.Models.OrderStatus.PendingApproval" />
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-send"></i> 送出簽核
            </button>
        </form>
        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-danger px-4"
                    onclick="return confirm('確定要作廢此出貨單嗎？')">
                <i class="bi bi-x-circle"></i> 作廢
            </button>
        </form>
    }
    @if (Model.Status == YunChenShipping.Models.OrderStatus.PendingApproval)
    {
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
            <input type="hidden" name="status" value="@YunChenShipping.Models.OrderStatus.Shipped" />
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-truck"></i> 確認出貨
            </button>
        </form>
    }
    @if (Model.Status == YunChenShipping.Models.OrderStatus.Shipped)
    {
        <form asp-action="UpdateStatus" asp-route-id="@Model.Id" method="post" class="d-inline">
            <input type="hidden" name="status" value="@YunChenShipping.Models.OrderStatus.Completed" />
            <button type="submit" class="btn btn-success px-4">
                <i class="bi bi-check-circle"></i> 完成
            </button>
        </form>
    }
</div>
