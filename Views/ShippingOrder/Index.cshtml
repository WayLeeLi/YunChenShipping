@model YunChenShipping.Models.PaginatedList<YunChenShipping.Models.ShippingOrder>
@{
    ViewData["Title"] = "出貨單管理";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-search"></i> 查詢條件
    </div>
    <div class="form-card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label-custom">單號/發票號/訂單號</label>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="請輸入關鍵字" />
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">開始日期</label>
                <input type="date" name="startDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">結束日期</label>
                <input type="date" name="endDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">狀態</label>
                <select name="status" class="form-select">
                    <option value="">全部狀態</option>
                    <option value="0">草稿</option>
                    <option value="1">待簽核</option>
                    <option value="2">已出貨</option>
                    <option value="3">已完成</option>
                    <option value="4">作廢</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> 查詢
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">清除</a>
            </div>
        </form>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-truck"></i> 出貨單列表</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus"></i> 新增出貨單
        </a>
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>出貨單號</th>
                        <th>客戶名稱</th>
                        <th>出貨日期</th>
                        <th>訂單號碼</th>
                        <th class="text-end">總計</th>
                        <th>排序</th>
                        <th>狀態</th>
                        <th>簽核</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.OrderNo</strong></td>
                            <td>@item.Customer?.Name</td>
                            <td>@item.OrderDate.ToString("yyyy/MM/dd")</td>
                            <td>@(item.ReferenceNo ?? "-")</td>
                            <td class="text-end fw-bold">@(item.Total == 0 ? "" : item.Total.ToString("N0"))</td>
                            <td>@item.SortOrder</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case YunChenShipping.Models.OrderStatus.Draft:
                                        <span class="badge bg-secondary">草稿</span>
                                        break;
                                    case YunChenShipping.Models.OrderStatus.PendingApproval:
                                        <span class="badge bg-warning">待簽核</span>
                                        break;
                                    case YunChenShipping.Models.OrderStatus.Shipped:
                                        <span class="badge bg-primary">已出貨</span>
                                        break;
                                    case YunChenShipping.Models.OrderStatus.Completed:
                                        <span class="badge bg-success">已完成</span>
                                        break;
                                    case YunChenShipping.Models.OrderStatus.Cancelled:
                                        <span class="badge bg-danger">作廢</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (item.ManagerApproved && item.AccountingApproved && item.HandlerApproved)
                                {
                                    <span class="badge bg-success">已簽核</span>
                                }
                                else if (item.Status == YunChenShipping.Models.OrderStatus.PendingApproval)
                                {
                                    <span class="badge bg-warning">簽核中</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">-</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="詳情">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Copy" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="複製">
                                    <i class="bi bi-copy"></i>
                                </a>
                                @if (item.Status == YunChenShipping.Models.OrderStatus.Draft)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="編輯">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                <form asp-action="DeletePermanent" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                            onclick="return confirm('⚠️ 確定要永久刪除此出貨單嗎？此操作無法復原！')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                <p class="mt-2">暫無資料</p>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_Pager", Model)
        }
    </div>
</div>

@section Scripts {
    <script>
        function cancelOrder(id) {
            if (confirm('確定要作廢此出貨單嗎？')) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '/ShippingOrder/Cancel/' + id,
                    type: 'POST',
                    data: { __RequestVerificationToken: token },
                    success: function() {
                        location.reload();
                    },
                    error: function() {
                        alert('操作失敗，請稍後重試');
                    }
                });
            }
        }
    </script>
}
