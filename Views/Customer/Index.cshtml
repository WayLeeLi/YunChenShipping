@model YunChenShipping.Models.PaginatedList<YunChenShipping.Models.Customer>
@{
    ViewData["Title"] = "客戶管理";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-search"></i> 查詢條件
    </div>
    <div class="form-card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label-custom">客戶名稱/電話/統編</label>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="請輸入關鍵字" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> 查詢
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">清除</a>
            </div>
        </form>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people"></i> 客戶列表</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus"></i> 新增客戶
        </a>
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>客戶編號</th>
                        <th>客戶名稱</th>
                        <th>統一編號</th>
                        <th>電話</th>
                        <th>聯絡人</th>
                        <th>付款方式</th>
                        <th>狀態</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@(item.TaxId ?? "-")</td>
                            <td>@(item.Phone ?? "-")</td>
                            <td>@(item.Contacts?.FirstOrDefault(c => c.IsPrimary)?.Name ?? item.ContactPerson ?? "-")</td>
                            <td>@Html.DisplayFor(modelItem => item.PaymentMethod)</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">啟用</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">停用</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="編輯">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="詳情">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="DeletePermanent" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                            onclick="return confirm('⚠️ 確定要永久刪除此客戶嗎？此操作無法復原！')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                <p class="mt-2">暫無資料</p>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_Pager", Model)
        }
    </div>
</div>
