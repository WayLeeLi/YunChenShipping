@model YunChenShipping.Models.Customer
@{
    ViewData["Title"] = "客戶管理 / 新增客戶";
}

<form asp-action="Create" method="post" id="mainForm">
    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-person-plus"></i> 新增客戶
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 客戶名稱</label>
                <div class="col"><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
                <label class="form-label-custom">統一編號</label>
                <div class="col"><input asp-for="TaxId" class="form-control" /></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">電話</label>
                <div class="col"><input asp-for="Phone" class="form-control" /></div>
                <label class="form-label-custom">傳真</label>
                <div class="col"><input asp-for="Fax" class="form-control" /></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">付款方式</label>
                <div class="col"><select asp-for="PaymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<YunChenShipping.Models.PaymentMethod>()"></select></div>
                <label class="form-label-custom">備註</label>
                <div class="col"><input asp-for="Remarks" class="form-control" /></div>
            </div>
        </div>
    </div>

    <!-- 聯絡人 -->
    <div class="form-card">
        <div class="form-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-person-lines-fill"></i> 聯絡人（可多筆）</span>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addContact()">
                <i class="bi bi-plus"></i> 新增聯絡人
            </button>
        </div>
        <div class="form-card-body">
            <div id="contactContainer">
                <div class="row mb-3 align-items-center">
                    <label class="form-label-custom"><span class="required">●</span> 姓名</label>
                    <div class="col"><input type="text" name="contactNames" class="form-control" /></div>
                    <label class="form-label-custom">電話</label>
                    <div class="col"><input type="text" name="contactPhones" class="form-control" /></div>
                    <label class="form-label-custom">職稱</label>
                    <div class="col"><input type="text" name="contactTitles" class="form-control" /></div>
                    <div class="col-auto">
                        <div class="form-check"><input type="checkbox" name="contactIsPrimary" class="form-check-input" value="true" checked /><label class="form-check-label small">主要聯絡人</label></div>
                    </div>
                    <div class="col-auto">
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContact(this)"><i class="bi bi-trash"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 交貨地址 -->
    <div class="form-card">
        <div class="form-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-geo-alt"></i> 交貨地址（可多筆）</span>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addAddress()">
                <i class="bi bi-plus"></i> 新增地址
            </button>
        </div>
        <div class="form-card-body">
            <div id="addressContainer">
                <div class="row mb-2 address-row align-items-center">
                    <div class="col-md-2"><label class="form-label-custom mb-0"><span class="required">●</span> 交貨地址</label></div>
                    <div class="col-md-6"><input type="text" name="addresses" class="form-control form-control-sm" /></div>
                    <div class="col-md-2">
                        <div class="form-check"><input type="checkbox" name="addressIsDefault" class="form-check-input" value="true" checked /><label class="form-check-label small">預設地址</label></div>
                    </div>
                    <div class="col-md-2"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAddress(this)"><i class="bi bi-trash"></i> 刪除</button></div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left"></i> 回上一頁
        </a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> 確定新增
        </button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function addContact() {
            var container = document.getElementById('contactContainer');
            var div = document.createElement('div');
            div.className = 'row mb-3 align-items-center';
            div.innerHTML = `
                <label class="form-label-custom"><span class="required">●</span> 姓名</label>
                <div class="col"><input type="text" name="contactNames" class="form-control" /></div>
                <label class="form-label-custom">電話</label>
                <div class="col"><input type="text" name="contactPhones" class="form-control" /></div>
                <label class="form-label-custom">職稱</label>
                <div class="col"><input type="text" name="contactTitles" class="form-control" /></div>
                <div class="col-auto">
                    <div class="form-check"><input type="checkbox" name="contactIsPrimary" class="form-check-input" value="true" /><label class="form-check-label small">主要聯絡人</label></div>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContact(this)"><i class="bi bi-trash"></i></button>
                </div>
            `;
            container.appendChild(div);
        }

        function removeContact(btn) {
            var container = document.getElementById('contactContainer');
            if (container.children.length > 1) {
                btn.closest('.row').remove();
            }
        }

        function addAddress() {
            var container = document.getElementById('addressContainer');
            var div = document.createElement('div');
            div.className = 'row mb-3 align-items-center';
            div.innerHTML = `
                <label class="form-label-custom"><span class="required">●</span> 交貨地址</label>
                <div class="col"><input type="text" name="addresses" class="form-control" /></div>
                <div class="col-auto">
                    <div class="form-check"><input type="checkbox" name="addressIsDefault" class="form-check-input" value="true" /><label class="form-check-label small">預設地址</label></div>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAddress(this)"><i class="bi bi-trash"></i></button>
                </div>
            `;
            container.appendChild(div);
        }

        function removeAddress(btn) {
            var container = document.getElementById('addressContainer');
            if (container.children.length > 1) {
                btn.closest('.row').remove();
            }
        }
    </script>
}
