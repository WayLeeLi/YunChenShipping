@model YunChenShipping.Models.Customer
@{
    ViewData["Title"] = "客戶管理 / 編輯客戶";
}

<form asp-action="Edit" method="post" id="mainForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedBy" />

    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-pencil"></i> 基本資料
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 客戶名稱</label>
                <div class="col"><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
                <label class="form-label-custom">統一編號</label>
                <div class="col"><input asp-for="TaxId" class="form-control" /></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">電話</label>
                <div class="col"><input asp-for="Phone" class="form-control" /></div>
                <label class="form-label-custom">傳真</label>
                <div class="col"><input asp-for="Fax" class="form-control" /></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 付款方式</label>
                <div class="col"><select asp-for="PaymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<YunChenShipping.Models.PaymentMethod>()"></select></div>
                <label class="form-label-custom">備註</label>
                <div class="col"><input asp-for="Remarks" class="form-control" /></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">狀態</label>
                <div class="col"><select asp-for="IsActive" class="form-select"><option value="true">啟用</option><option value="false">停用</option></select></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">排序</label>
                <div class="col"><input asp-for="SortOrder" class="form-control" type="number" /></div>
            </div>
        </div>
    </div>

    <!-- 聯絡人 -->
    <div class="form-card">
        <div class="form-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-person-lines-fill"></i> 聯絡人</span>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addContact()"><i class="bi bi-plus"></i> 新增</button>
        </div>
        <div class="form-card-body">
            <div id="contactContainer">
                @if (Model.Contacts != null && Model.Contacts.Any())
                {
                    var contactIndex = 0;
                    @foreach (var contact in Model.Contacts)
                    {
                        <div class="row mb-2 contact-row align-items-center">
                            <label class="form-label-custom">姓名</label>
                            <div class="col"><input type="text" name="contactNames" class="form-control form-control-sm" value="@contact.Name" /></div>
                            <label class="form-label-custom">電話</label>
                            <div class="col"><input type="text" name="contactPhones" class="form-control form-control-sm" value="@contact.Phone" /></div>
                            <label class="form-label-custom">職稱</label>
                            <div class="col"><input type="text" name="contactTitles" class="form-control form-control-sm" value="@contact.Title" /></div>
                            <div class="col-auto"><div class="form-check"><input type="radio" name="contactIsPrimary" class="form-check-input" value="@contactIndex" @(contact.IsPrimary ? "checked" : "") /><label class="form-check-label small">主要</label></div></div>
                            <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContact(this)"><i class="bi bi-trash"></i></button></div>
                        </div>
                        contactIndex++;
                    }
                }
            </div>
        </div>
    </div>

    <!-- 交貨地址 -->
    <div class="form-card">
        <div class="form-card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-geo-alt"></i> 交貨地址</span>
            <button type="button" class="btn btn-sm btn-outline-primary" onclick="addAddress()"><i class="bi bi-plus"></i> 新增</button>
        </div>
        <div class="form-card-body">
            <div id="addressContainer">
                @if (Model.Addresses != null && Model.Addresses.Any())
                {
                    @foreach (var address in Model.Addresses)
                    {
                        <div class="row mb-2 address-row align-items-center">
                            <label class="form-label-custom">地址</label>
                            <div class="col"><input type="text" name="addresses" class="form-control form-control-sm" value="@address.Address" /></div>
                            <div class="col-auto"><div class="form-check"><input type="checkbox" name="addressIsDefault" class="form-check-input" value="true" @(address.IsDefault ? "checked" : "") /><label class="form-check-label small">預設</label></div></div>
                            <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAddress(this)"><i class="bi bi-trash"></i></button></div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4"><i class="bi bi-arrow-left"></i> 回上一頁</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> 確定修改</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function addContact() {
            var c = document.getElementById('contactContainer');
            var index = c.children.length;
            var d = document.createElement('div');
            d.className = 'row mb-2 contact-row align-items-center';
            d.innerHTML = '<label class="form-label-custom">姓名</label><div class="col"><input type="text" name="contactNames" class="form-control form-control-sm" /></div><label class="form-label-custom">電話</label><div class="col"><input type="text" name="contactPhones" class="form-control form-control-sm" /></div><label class="form-label-custom">職稱</label><div class="col"><input type="text" name="contactTitles" class="form-control form-control-sm" /></div><div class="col-auto"><div class="form-check"><input type="radio" name="contactIsPrimary" class="form-check-input" value="' + index + '" /><label class="form-check-label small">主要</label></div></div><div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContact(this)"><i class="bi bi-trash"></i></button></div>';
            c.appendChild(d);
        }
        function removeContact(b) { if (b.closest('#contactContainer').children.length > 1) b.closest('.contact-row').remove(); }
        function addAddress() {
            var c = document.getElementById('addressContainer');
            var d = document.createElement('div');
            d.className = 'row mb-2 address-row align-items-center';
            d.innerHTML = '<label class="form-label-custom">地址</label><div class="col"><input type="text" name="addresses" class="form-control form-control-sm" /></div><div class="col-auto"><div class="form-check"><input type="checkbox" name="addressIsDefault" class="form-check-input" value="true" /><label class="form-check-label small">預設</label></div></div><div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAddress(this)"><i class="bi bi-trash"></i></button></div>';
            c.appendChild(d);
        }
        function removeAddress(b) { if (b.closest('#addressContainer').children.length > 1) b.closest('.address-row').remove(); }
    </script>
}
