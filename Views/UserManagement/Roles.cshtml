@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "角色管理";
}

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-shield"></i> 角色管理</span>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createRoleModal">
            <i class="bi bi-plus"></i> 新增角色
        </button>
    </div>
    <div class="form-card-body">
        <!-- 角色列表 -->
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>角色名稱</th>
                        <th>說明</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td>
                                @switch (role.Name)
                                {
                                    case "Admin":
                                        <span class="badge bg-danger">Admin</span>
                                        break;
                                    case "Sales":
                                        <span class="badge bg-primary">Sales</span>
                                        break;
                                    case "Accounting":
                                        <span class="badge bg-success">Accounting</span>
                                        break;
                                    case "Warehouse":
                                        <span class="badge bg-warning">Warehouse</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@role.Name</span>
                                        break;
                                }
                            </td>
                            <td>
                                @switch (role.Name)
                                {
                                    case "Admin":
                                        <span>系統管理員，擁有所有權限</span>
                                        break;
                                    case "Sales":
                                        <span>業務人員，可管理客戶、產品、出貨單</span>
                                        break;
                                    case "Accounting":
                                        <span>會計人員，可簽核出貨單、查看報表</span>
                                        break;
                                    case "Warehouse":
                                        <span>倉管人員，可管理出貨流程</span>
                                        break;
                                    default:
                                        <span>-</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="EditRolePermissions" asp-route-roleName="@role.Name"
                                   class="btn btn-sm btn-outline-primary" title="設定權限">
                                    <i class="bi bi-key"></i> 設定權限
                                </a>
                                @if (role.Name != "Admin" && role.Name != "Sales" && role.Name != "Accounting" && role.Name != "Warehouse")
                                {
                                    <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                                onclick="return confirm('確定要刪除此角色嗎？')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted ms-2">系統角色</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 新增角色 Modal -->
<div class="modal fade" id="createRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateRole" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">新增角色</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">角色名稱</label>
                        <input type="text" name="roleName" class="form-control" placeholder="請輸入角色名稱" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">確定新增</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center mt-4">
    <a asp-action="Index" class="btn btn-secondary px-4">
        <i class="bi bi-arrow-left"></i> 回用戶管理
    </a>
</div>
