@model IEnumerable<YunChenShipping.Controllers.UserViewModel>
@{
    ViewData["Title"] = "用戶管理";

    // 角色顯示名稱與顏色對應
    var roleDisplay = new Dictionary<string, (string Label, string Css)>
    {
        { "Admin", ("管理員", "bg-danger") },
        { "Sales", ("業務", "bg-primary") },
        { "Accounting", ("會計", "bg-success") },
        { "Warehouse", ("倉管", "bg-warning text-dark") },
    };
    string defaultCss = "bg-secondary";
}

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people"></i> 用戶列表</span>
        <div>
            <a asp-action="Roles" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-shield"></i> 角色管理
            </a>
            <a asp-action="Create" class="btn btn-sm btn-primary">
                <i class="bi bi-plus"></i> 新增使用者
            </a>
        </div>
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>帳號</th>
                        <th>中文名</th>
                        <th>角色</th>
                        <th>狀態</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Email</td>
                            <td>@(item.ChineseName ?? "-")</td>
                            <td>
                                @if (item.Roles.Any())
                                {
                                    foreach (var roleName in item.Roles)
                                    {
                                        var (label, css) = roleDisplay.TryGetValue(roleName, out var r) ? r : (roleName, defaultCss);
                                        <span class="badge @css me-1">@label</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">未指派</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-success">啟用</span>
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="編輯">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                            onclick="return confirm('確定要刪除此使用者嗎？')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                <p class="mt-2">暫無資料</p>
            </div>
        }
    </div>
</div>
