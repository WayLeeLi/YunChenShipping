@model YunChenShipping.Controllers.CreateUserViewModel
@{
    ViewData["Title"] = "用戶管理 / 新增用戶";
    var roles = ViewBag.Roles as List<string>;
}

<form asp-action="Create" method="post" id="mainForm">
    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-person-plus"></i> 新增用戶
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 帳號</label>
                <div class="col"><input asp-for="Email" class="form-control" placeholder="電子郵件" /><span asp-validation-for="Email" class="text-danger small"></span></div>
                <label class="form-label-custom">角色</label>
                <div class="col"><select asp-for="Role" class="form-select"><option value="">請選擇</option>@if (roles != null) { @foreach (var role in roles) { <option value="@role">@role</option> } }</select></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 密碼</label>
                <div class="col"><input asp-for="Password" class="form-control" placeholder="至少6位" /><span asp-validation-for="Password" class="text-danger small"></span></div>
                <label class="form-label-custom"><span class="required">●</span> 確認密碼</label>
                <div class="col"><input asp-for="ConfirmPassword" class="form-control" /><span asp-validation-for="ConfirmPassword" class="text-danger small"></span></div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4"><i class="bi bi-arrow-left"></i> 回上一頁</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> 確定新增</button>
    </div>
</form>
