@model YunChenShipping.Models.DeliveryMethodSetting
@{
    ViewData["Title"] = "系統管理 / 編輯運送方式";
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />

    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-pencil"></i> 編輯運送方式
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 運送方式</label>
                <div class="col"><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">排序</label>
                <div class="col"><input asp-for="SortOrder" class="form-control" type="number" /><span asp-validation-for="SortOrder" class="text-danger small"></span></div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4"><i class="bi bi-arrow-left"></i> 回上一頁</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> 確定修改</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
