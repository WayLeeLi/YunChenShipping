@model YunChenShipping.Models.Product
@{
    ViewData["Title"] = "產品管理 / 產品詳情";
}

<!-- 基本資料 -->
<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-box"></i> 基本資料
    </div>
    <div class="form-card-body">
        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">產品編號</label>
            </div>
            <div class="col-md-4">
                <span>@Model.Id</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">PART NO</label>
            </div>
            <div class="col-md-4">
                <span>@Model.PartNo</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">產品名稱及規格</label>
            </div>
            <div class="col-md-10">
                <span>@Model.Name</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">單位</label>
            </div>
            <div class="col-md-4">
                <span>@Model.Unit</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">標準單價</label>
            </div>
            <div class="col-md-4">
                <span class="text-primary fw-bold">@Model.StandardPrice.ToString("N2")</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">課稅別</label>
            </div>
            <div class="col-md-4">
                @switch (Model.TaxType)
                {
                    case YunChenShipping.Models.TaxType.Taxable:
                        <span class="badge bg-warning">應稅</span>
                        break;
                    case YunChenShipping.Models.TaxType.ZeroTax:
                        <span class="badge bg-info">零稅</span>
                        break;
                    case YunChenShipping.Models.TaxType.TaxFree:
                        <span class="badge bg-success">免稅</span>
                        break;
                }
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">狀態</label>
            </div>
            <div class="col-md-4">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">啟用</span>
                }
                else
                {
                    <span class="badge bg-secondary">停用</span>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">備註</label>
            </div>
            <div class="col-md-10">
                <span>@(Model.Remarks ?? "-")</span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-2">
                <label class="form-label-custom">建立時間</label>
            </div>
            <div class="col-md-4">
                <span>@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            <div class="col-md-2">
                <label class="form-label-custom">建立人員</label>
            </div>
            <div class="col-md-4">
                <span>@(Model.CreatedBy ?? "-")</span>
            </div>
        </div>
    </div>
</div>

<!-- 單價歷史紀錄 -->
<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-clock-history"></i> 單價歷史紀錄
    </div>
    <div class="form-card-body">
        @if (Model.PriceHistory != null && Model.PriceHistory.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>變更時間</th>
                            <th>歷史單價</th>
                            <th>變更人員</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var history in Model.PriceHistory)
                        {
                            <tr>
                                <td>@history.ChangedAt.ToString("yyyy/MM/dd HH:mm:ss")</td>
                                <td class="text-end fw-bold">@history.Price.ToString("N2")</td>
                                <td>@(history.ChangedBy ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-3">
                <p class="mb-0">暫無價格變更紀錄</p>
            </div>
        }
    </div>
</div>

<!-- 按鈕 -->
<div class="d-flex justify-content-center gap-3 mt-4">
    <a asp-action="Index" class="btn btn-secondary px-4">
        <i class="bi bi-arrow-left"></i> 回上一頁
    </a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">
        <i class="bi bi-pencil"></i> 編輯
    </a>
</div>
