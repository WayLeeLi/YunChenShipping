@model YunChenShipping.Models.Product
@{
    ViewData["Title"] = "產品管理 / 編輯產品";
}

<form asp-action="Edit" method="post" id="mainForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="CreatedBy" />
    <input type="hidden" asp-for="Unit" id="unitHidden" />

    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-pencil"></i> 編輯產品
        </div>
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> PART NO</label>
                <div class="col"><input asp-for="PartNo" class="form-control" /><span asp-validation-for="PartNo" class="text-danger small"></span></div>
                <label class="form-label-custom"><span class="required">●</span> 單位</label>
                <div class="col"><select asp-for="Unit" class="form-select" id="unitSelect"><option value="">請選擇</option></select></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 產品名稱</label>
                <div class="col"><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
                <label class="form-label-custom"><span class="required">●</span> 標準單價</label>
                <div class="col"><input asp-for="StandardPrice" class="form-control" type="number" step="0.01" /><span asp-validation-for="StandardPrice" class="text-danger small"></span></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom"><span class="required">●</span> 課稅別</label>
                <div class="col"><select asp-for="TaxType" class="form-select" asp-items="Html.GetEnumSelectList<YunChenShipping.Models.TaxType>()"></select></div>
                <label class="form-label-custom">狀態</label>
                <div class="col"><select asp-for="IsActive" class="form-select"><option value="true">啟用</option><option value="false">停用</option></select></div>
            </div>

            <div class="row mb-2 align-items-center">
                <label class="form-label-custom">備註</label>
                <div class="col"><input asp-for="Remarks" class="form-control" /></div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4"><i class="bi bi-arrow-left"></i> 回上一頁</a>
        <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg"></i> 確定修改</button>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            var currentValue = $('#unitHidden').val() || '';
            $.get('/UnitSetting/GetUnits', function(data) {
                var select = $('#unitSelect');
                select.find('option:gt(0)').remove();
                data.forEach(function(unit) {
                    var option = $('<option value="' + unit + '">' + unit + '</option>');
                    if (unit === currentValue) {
                        option.attr('selected', 'selected');
                    }
                    select.append(option);
                });
            });

            // 表單提交前同步 select 值到 hidden field
            $('#mainForm').on('submit', function() {
                $('#unitHidden').val($('#unitSelect').val());
            });
        });
    </script>
}
