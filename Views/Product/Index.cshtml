@model YunChenShipping.Models.PaginatedList<YunChenShipping.Models.Product>
@{
    ViewData["Title"] = "產品管理";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-search"></i> 查詢條件
    </div>
    <div class="form-card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label-custom">產品名稱/PART NO</label>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="請輸入關鍵字" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> 查詢
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">清除</a>
            </div>
        </form>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-box"></i> 產品列表</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus"></i> 新增產品
        </a>
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>產品編號</th>
                        <th>PART NO</th>
                        <th>產品名稱及規格</th>
                        <th>單位</th>
                        <th>標準單價</th>
                        <th>課稅別</th>
                        <th>狀態</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.PartNo</td>
                            <td>@item.Name</td>
                            <td>@item.Unit</td>
                            <td class="text-end">@item.StandardPrice.ToString("N2")</td>
                            <td>
                                @switch (item.TaxType)
                                {
                                    case YunChenShipping.Models.TaxType.Taxable:
                                        <span class="badge bg-warning">應稅</span>
                                        break;
                                    case YunChenShipping.Models.TaxType.ZeroTax:
                                        <span class="badge bg-info">零稅</span>
                                        break;
                                    case YunChenShipping.Models.TaxType.TaxFree:
                                        <span class="badge bg-success">免稅</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">啟用</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">停用</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="編輯">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="詳情">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="DeletePermanent" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                            onclick="return confirm('⚠️ 確定要永久刪除此產品嗎？此操作無法復原！')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                <p class="mt-2">暫無資料</p>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_Pager", Model)
        }
    </div>
</div>
