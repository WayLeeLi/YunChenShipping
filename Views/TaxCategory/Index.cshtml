@model IEnumerable<YunChenShipping.Models.TaxCategory>
@{
    ViewData["Title"] = "系統管理 / 營業稅設定";
}

<div class="form-card">
    <div class="form-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-percent"></i> 營業稅列表</span>
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="bi bi-plus"></i> 新增營業稅
        </a>
    </div>
    <div class="form-card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>營業稅名稱</th>
                        <th>稅率(%)</th>
                        <th>排序</th>
                        <th>建立時間</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.TaxRate.ToString("N2")%</td>
                            <td>@item.SortOrder</td>
                            <td>@item.CreatedAt.ToString("yyyy/MM/dd")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="編輯">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="刪除"
                                            onclick="return confirm('確定要刪除此營業稅嗎？')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                <p class="mt-2">暫無資料</p>
            </div>
        }
    </div>
</div>
