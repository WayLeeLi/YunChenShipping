@model YunChenShipping.Controllers.SystemSettingViewModel
@{
    ViewData["Title"] = "系統設定";
}

<form asp-action="Save" method="post">
    <!-- 公司資料 -->
    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-building"></i> 公司抬頭資料
        </div>
        <div class="form-card-body">
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 公司名稱</label>
                </div>
                <div class="col-md-10">
                    <input asp-for="CompanyName" class="form-control" />
                    <small class="form-text">供列印表頭套用</small>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">公司地址</label>
                </div>
                <div class="col-md-10">
                    <input asp-for="CompanyAddress" class="form-control" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">公司電話</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="CompanyPhone" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">公司傳真</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="CompanyFax" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <!-- 出貨單設定 -->
    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-gear"></i> 出貨單設定
        </div>
        <div class="form-card-body">
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 出貨單號前綴</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="OrderNoPrefix" class="form-control" />
                    <small class="form-text">例：SO，編號格式為 {前綴}-{日期}-{流水號}</small>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom"><span class="required">●</span> 營業稅率(%)</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="TaxRate" class="form-control" type="number" step="0.1" min="0" max="100" />
                    <small class="form-text">預設5%，可依政策調整</small>
                </div>
            </div>
        </div>
    </div>

    <!-- 列印設定 -->
    <div class="form-card">
        <div class="form-card-header">
            <i class="bi bi-printer"></i> 列印版面設定
        </div>
        <div class="form-card-body">
            <div class="row mb-3">
                <div class="col-md-2">
                    <label class="form-label-custom">上邊距(mm)</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="PrintMarginTop" class="form-control" type="number" min="0" max="50" />
                </div>
                <div class="col-md-2">
                    <label class="form-label-custom">左邊距(mm)</label>
                </div>
                <div class="col-md-4">
                    <input asp-for="PrintMarginLeft" class="form-control" type="number" min="0" max="50" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <small class="form-text text-muted">
                        因應不同印表機／紙張誤差，可微調列印邊距。建議先用白紙測試對齊後再正式列印。
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- 按鈕 -->
    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left"></i> 重新載入
        </a>
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> 儲存設定
        </button>
    </div>
</form>
